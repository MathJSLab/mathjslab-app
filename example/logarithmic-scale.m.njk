            "pt": "Valores em escala logarítmica"
        },
        "values": {
            "en": "values from 10^0 to 10^4",
            "es": "valores desde 10^0 hasta 10^4",
            "pt": "valores de 10^0 até 10^4"
        },
        "logs": {
            "en": "base-10 logarithms recover the exponents",
