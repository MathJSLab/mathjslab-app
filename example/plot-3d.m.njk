---
% {{ comments.title[lang] }}
clear

% {{ comments.spiral[lang] }}
t = linspace(0, 8*pi, 80)
x = sin(t)
y = cos(t)
z = t ./ (8*pi)
plot3(x, y, z, 'm-')
help plot3

% {{ comments.surface[lang] }}
axis = linspace(0, 314, 14)
[X, Y] = meshgrid(axis, axis)
Z = sin(X ./ 50) .* cos(Y ./ 50) .* 50 + 50
surf(X, Y, Z)
help surf
