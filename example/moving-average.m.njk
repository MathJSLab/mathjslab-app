---
% {{ comments.title[lang] }}
clear
% {{ comments.signal[lang] }}
signal = [3, 4, 8, 6, 5, 7, 9]
% {{ comments.average[lang] }}
moving_average = (signal(1:5) + signal(2:6) + signal(3:7))/3
