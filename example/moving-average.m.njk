            "pt": "Média móvel de três pontos"
        },
        "signal": {
            "en": "short noisy signal",
            "es": "señal corta con ruido",
            "pt": "sinal curto com ruído"
        },
        "average": {
            "en": "average each group of three consecutive values",
            "es": "promediar cada grupo de tres valores consecutivos",
