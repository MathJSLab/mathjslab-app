% {{ comments.title[lang] }}
function y = safe_inverse(x)
  try
    if x == 0
      error("division by zero");
    end
    y = 1/x;
  catch
    y = NaN;
  end
end

% {{ comments.safe[lang] }}
a = safe_inverse(4)
b = safe_inverse(0)
