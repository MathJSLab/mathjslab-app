---
% {{ comments.title[lang] }}
% {{ comments.note[lang] }}
classdef Account
  properties
    Owner = "Ana";
    Balance = 0;
  end

  methods
    function obj = deposit(obj, amount)
      obj.Balance = obj.Balance + amount;
    end

    function value = currentBalance(obj)
      value = obj.Balance;
    end
  end
end

