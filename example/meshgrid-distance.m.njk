---
% {{ comments.title[lang] }}
clear
% {{ comments.grid[lang] }}
x = -2:2
y = -1:1
[X, Y] = meshgrid(x, y)
% {{ comments.distance[lang] }}
R = sqrt(X.^2 + Y.^2)
