---json
{
    "comments": {
        "title": {
            "en": "Distance on a rectangular grid",
            "es": "Distancia en una cuadrícula rectangular",
            "pt": "Distância em uma grade retangular"
        },
        "grid": {
            "en": "create x-y coordinate matrices",
            "es": "crear matrices de coordenadas x-y",
            "pt": "criar matrizes de coordenadas x-y"
        },
        "distance": {
            "en": "distance from the origin at each grid point",
            "es": "distancia al origen en cada punto de la cuadrícula",
            "pt": "distância até a origem em cada ponto da grade"
        }
