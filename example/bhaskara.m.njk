% {{ comments.title[lang] }}
clear
% {{ comments.coefficients[lang] }}
a = 1
b = -10
c = 21
% {{ comments.formula[lang] }}
Delta = b^2-4*a*c
x1 = (-b + sqrt(Delta))/(2*a)
x2 = (-b - sqrt(Delta))/(2*a)
% {{ comments.function[lang] }}
f = @(x) a*x^2+b*x+c
% {{ comments.plot[lang] }}
plot2d(f(X),X,min([x1,x2,0])-1,max([x1,x2,0])+1)